<mujoco model="pushing_scene_cfg_match">



  <asset>
    <material name="mat_workspace"  rgba="0.70 0.70 0.70 1" shininess="0.05"/>
    <material name="mat_box"        rgba="0.43 0.20 0.66 1" shininess="0.2"/>
    <material name="mat_pusher"     rgba="0.66 0.41 0.20 1" shininess="0.2"/>
    <material name="mat_goal_g"     rgba="0 1 0 0.35"/>
    <material name="mat_goal_r"     rgba="1 0 0 0.35"/>
    <material name="mat_goal_b"     rgba="0 0 1 0.35"/>
    <material name="mat_ground"     rgba="0.5 0.5 0.5 1"/>
  </asset>

  <worldbody>
    <!-- light -->
    <light name="light" type="directional" dir="0 0 -1" diffuse="0.75 0.75 0.75" specular="0.2 0.2 0.2"/>

    <!-- Ground -->
    <geom name="ground" type="plane" size="5 5 0.1" material="mat_ground"/>

    <!-- Workspace -->
    <body name="workspace" pos="0 0 0.005" quat="0 0 0 1">
      <geom name="workspace_geom" type="box"
            size="0.4 1.0 0.01"
            material="mat_workspace"
            friction="0.5 0.005 0.0001"/>
    </body>

    <!-- Pusher -->
    <body name="pusher" pos="0 -0.9 0.0225" quat="0 0 0 1" gravcomp="1">
        <joint name="pusher_x" type="slide" axis="1 0 0" damping="1"/> 
        <joint name="pusher_y" type="slide" axis="0 1 0" damping="1"/>
        <joint name="pusher_z" type="slide" axis="0 0 1" damping="1"/>
        <geom name="pusher_geom"
              type="sphere"
              size="0.0125"
              material="mat_pusher"
              friction="0.5 0.005 0.0001"
              mass="0.5"/>
    </body>

    <!-- Box -->
    <body name="box" pos="0 -0.8 0.045" quat="0 0 0 1">
      <freejoint/>
      <geom name="box_geom" type="box"
            size="0.06 0.05 0.035"
            material="mat_box"
            friction="0.0 0.001 0.0001"
            mass="0.5"/>
    </body>

    <!-- goal -->
    <body name="goal_r" pos="0 0.8 0.045" quat="0 0 0 1" mocap="true">
      <geom name="goal_r_geom" 
            type="box" 
            size="0.06 0.05 0.035"
            material="mat_goal_r" 
            contype="0" 
            conaffinity="0"/>
    </body>

    <body name="goal_g" pos="0.2 0.8 0.045" quat="0 0 0 1" mocap="true">
      <geom name="goal_g_geom" 
            type="box" 
            size="0.06 0.05 0.035"
            material="mat_goal_g" 
            contype="0" 
            conaffinity="0"/>
    </body>

    <body name="goal_b" pos="-0.2 0.8 0.045" quat="0 0 0 1" mocap="true">
      <geom name="goal_b_geom" 
            type="box" 
            size="0.06 0.05 0.035"
            material="mat_goal_b" 
            contype="0" 
            conaffinity="0"/>
    </body>

  </worldbody>

  <actuator>
    <velocity name="pusher_vx" joint="pusher_x" kv="30"/>
    <velocity name="pusher_vy" joint="pusher_y" kv="30"/>
    <velocity name="pusher_vz" joint="pusher_z" kv="30"/>
  </actuator>

</mujoco>
